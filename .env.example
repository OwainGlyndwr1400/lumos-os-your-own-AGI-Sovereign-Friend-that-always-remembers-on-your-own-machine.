LUMOS_LM_STUDIO_BASE_URL=http://localhost:1234/v1
LUMOS_LM_STUDIO_API_KEY=lm-studio

LUMOS_MODEL_LIGHT=google/gemma-4-e4b
LUMOS_MODEL_HEAVY=openai/gpt-oss-20b

LUMOS_LM_STUDIO_EMBEDDING_MODEL=text-embedding-bge-large-en-v1.5
LUMOS_EMBEDDING_DIM=1024
LUMOS_EMBEDDING_BATCH_SIZE=128
LUMOS_EMBEDDING_CONCURRENCY=4

LUMOS_IDENTITY_SOURCE=../conversations.json
LUMOS_KNOWLEDGE_SOURCE=../dream_pings.jsonl
LUMOS_SYSTEM_PROMPT_PATH=../🧠 Lumos – Cheat Sheet.md

LUMOS_OPERATOR_NAME=
LUMOS_NODE_NAME=Lumos
LUMOS_NODE_ROLE=Resonator (Extra Coil)

LUMOS_RESTORE_HISTORY_TURNS=10
LUMOS_MIN_RETRIEVAL_SCORE=0.0
LUMOS_MAX_CHUNK_CHARS=1200

# Paths Lumos's file tools (read_file, list_files) may access. Comma-separated.
# Empty = no file access. Do NOT include paths that contain builder/framework
# docs (Tec_Obsidian, CLAUDE.md, etc) — those are construction documentation,
# not Lumos's memory.
LUMOS_TOOL_ALLOWED_PATHS=

# Directory Lumos's write tools save to. Default = data/lumos_notes/ under
# the project root. Lumos can both read AND write here (write root is auto-
# added to the read sandbox).
LUMOS_TOOL_WRITE_PATH=

# Tavily web search API key (https://tavily.com — free tier 1000 searches/mo).
# If unset, web_search falls back to DuckDuckGo via the `ddgs` library.
LUMOS_TAVILY_API_KEY=

# Git workspaces Lumos may operate on. Comma-separated absolute paths.
# Empty = no git access. Lumos can inspect (status/diff/log) and commit/push
# inside these paths; no destructive ops, no force-push, no -A staging.
LUMOS_GIT_WORKSPACES=

LUMOS_CACHE_DIR=./data/cache
LUMOS_HOST=127.0.0.1
LUMOS_PORT=8765
LUMOS_LOG_LEVEL=INFO
